# App
NEXT_PUBLIC_APP_NAME=Antigravity Chat
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Supabase (public - safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-only - NEVER expose in browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Antigravity Webhook
# Optional: if set, incoming webhooks must include a matching HMAC signature.
# Leave as 'your-webhook-secret' to accept all webhooks without verification (dev mode).
ANTIGRAVITY_WEBHOOK_SECRET=your-webhook-secret
